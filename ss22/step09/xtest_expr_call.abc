@ <stdio.hdr>                                                                    
@ "expr.hdr"                                                                     
@ "gen.hdr"
                                                                                 
fn main()
{                                                                                
    local expr: -> Expr;                                                         

    expr = createCallExpr(UStrCreate("foo"));
    addArgExpr(expr, createIntegerExpr(UStrCreate("4")));
    addArgExpr(expr, createIntegerExpr(UStrCreate("2")));

    printExprTree(expr);
    printf("\n");
    loadExpr(expr);
    releaseExpr(expr);                                                           
}                                                                                
